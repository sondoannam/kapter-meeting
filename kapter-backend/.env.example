PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
WEBAPP_BASE_URL=http://localhost:5173
NOTION_API_KEY=secret_notion_api_key
LOG_DIR=logs
LOG_LEVEL=debug
WS_AUDIO_NAMESPACE=/audio-stream
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=1
OPENAI_ENABLE_PROMPT_DUMP=false
GOOGLE_API_KEY=
GEMINI_API_VERSION=v1
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=120000
GEMINI_MAX_RETRIES=1
GEMINI_ENABLE_PROMPT_DUMP=false
GEMINI_THINKING_BUDGET=0
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen3.5:9b
OLLAMA_STRUCTURED_OUTPUT_MODE=auto
OLLAMA_TIMEOUT_MS=300000
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:5173

DATABASE_URL="postgresql://admin:Test%40123@localhost:5433/kapter_db?schema=public"
DIRECT_URL="postgresql://admin:Test%40123@localhost:5433/kapter_db?schema=public"
POSTGRES_USER=admin
POSTGRES_PASSWORD=Test@123
POSTGRES_DB=kapter_db
POSTGRES_PORT=5433
DATABASE_URL_DOCKER="postgresql://admin:Test%40123@postgres:5432/kapter_db?schema=public"
AI_WORKER_BASE_URL=http://127.0.0.1:8000
AI_WORKER_TIMEOUT_MS=30000
AI_WORKER_FILE_TIMEOUT_MS=600000
AI_WORKER_SHARED_SECRET=
MEETING_MEDIA_STORAGE_DRIVER=minio
MEETING_MEDIA_LOCAL_DIR=tmp/meeting-media
MEETING_MEDIA_MINIO_ENDPOINT=kapter-minio.sondndev.id.vn
MEETING_MEDIA_MINIO_PORT=443
MEETING_MEDIA_MINIO_USE_SSL=true
MEETING_MEDIA_MINIO_ACCESS_KEY=replace-with-your-minio-access-key
MEETING_MEDIA_MINIO_SECRET_KEY=replace-with-your-minio-secret-key
MEETING_MEDIA_MINIO_BUCKET=kapter-meetings
MEETING_MEDIA_MINIO_REGION=

NOTION_CLIENT_ID=your_client_id
NOTION_CLIENT_SECRET=your_client_secret
NOTION_OAUTH_REDIRECT_URI=http://localhost:3001/api/notion/callback

# Production examples
# CORS_ORIGIN=https://<your-webapp>.vercel.app
# CLERK_AUTHORIZED_PARTIES=https://<your-webapp>.vercel.app
# WEBAPP_BASE_URL=https://<your-webapp>.vercel.app
# AI_WORKER_BASE_URL=https://kapter-worker.sondndev.id.vn
# AI_WORKER_SHARED_SECRET=replace-with-a-random-shared-secret
# If backend and MinIO run on the same private Docker network, prefer:
# MEETING_MEDIA_MINIO_ENDPOINT=minio
# MEETING_MEDIA_MINIO_PORT=9000
# MEETING_MEDIA_MINIO_USE_SSL=false
# DATABASE_URL=postgresql://<user>:<password>@<provider-pooled-host>/<db>?sslmode=require
# DIRECT_URL=postgresql://<user>:<password>@<provider-direct-host>/<db>?sslmode=require
# If your provider exposes only one connection string, set DATABASE_URL and DIRECT_URL to the same value.
# NOTION_OAUTH_REDIRECT_URI=https://<your-backend-app>.herokuapp.com/api/notion/callback

OLLAMA_ENABLE_PROMPT_DUMP=false
MEETING_EXTRACTION_ENABLE_TRACE_DUMP=false
MEETING_EXTRACTION_TRACE_DIR=logs/meeting-extraction
