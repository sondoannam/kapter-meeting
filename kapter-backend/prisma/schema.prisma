generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  notionToken      String?
  notionDbId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clerkId          String?           @unique
  deletedAt        DateTime?
  imageUrl         String?
  meetings         Meeting[]
  NotionConnection NotionConnection?
  projects         Project[]
  subscription     Subscription?
  usageLedgers     UsageLedger[]
  voiceProfiles    VoiceProfile[]
  recurringSpeakerProfiles RecurringSpeakerProfile[]
}

model Meeting {
  id                      String                         @id @default(cuid())
  title                   String
  description             String?
  status                  MeetingStatus                  @default(RECORDING)
  ingestionSource         MeetingIngestionSource         @default(LIVE_CAPTURE)
  captureContext          CaptureContext?
  degradedWithoutSelfMic  Boolean                        @default(false)
  recorderLabelHint       String?
  artifactReviewStatus    MeetingArtifactReviewStatus    @default(PENDING)
  artifactExtractionError String?
  artifactApprovedAt      DateTime?
  speakerPostProcessStatus MeetingSpeakerPostProcessStatus @default(PENDING)
  speakerPostProcessedAt  DateTime?
  speakerPostProcessError String?
  audioUrl                String?
  summary                 String?
  userId                  String
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  externalMeetingId       String?
  projectId               String?
  actionItems             ActionItem[]
  artifactDraft           MeetingArtifactDraft?
  extractionChunks        MeetingExtractionChunk[]
  project                 Project?                       @relation(fields: [projectId], references: [id])
  promotedVoiceProfileSamples VoiceProfileSample[]
  recurringSpeakerSamples RecurringSpeakerSample[]
  user                    User                           @relation(fields: [userId], references: [id])
  audioBatches            MeetingAudioBatch[]
  contextUpdateProposals  ProjectContextUpdateProposal[]
  speakers                SpeakerProfile[]
  transcript              TranscriptSegment[]
  usageLedger             UsageLedger?

  @@index([externalMeetingId])
  @@index([projectId, createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  tier                   PlanTier           @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  billingProvider        String?
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier, status])
  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
}

model UsageLedger {
  id          String   @id @default(cuid())
  userId      String
  meetingId   String   @unique
  periodStart DateTime
  periodEnd   DateTime
  usedSeconds Int
  source      String   @default("meeting_capture")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart, periodEnd])
}

model Project {
  id                            String                         @id @default(cuid())
  title                         String
  description                   String?
  isDraft                       Boolean                        @default(false)
  notionProjectPageId           String?
  notionTaskDatabaseId          String?
  userId                        String
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  notionDestinationMode         NotionProjectDestinationMode?
  meetings                      Meeting[]
  user                          User                           @relation(fields: [userId], references: [id])
  context                       ProjectContext?
  projectContextUpdateProposals ProjectContextUpdateProposal[]

  @@index([userId, updatedAt])
}

model ProjectContext {
  id                 String   @id @default(cuid())
  initialDescription String?
  contextMarkdown    String?
  projectId          String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectContextUpdateProposal {
  id                      String                       @id @default(cuid())
  proposedContextMarkdown String
  changeSummary           String
  status                  ProjectContextProposalStatus @default(PENDING)
  projectId               String
  meetingId               String
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  project                 Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meeting                 Meeting                      @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([meetingId, status, createdAt])
}

model MeetingAudioBatch {
  id             String                  @id @default(cuid())
  streamId       String
  sourceType     AudioSourceType?
  sequenceStart  Int
  sequenceEnd    Int
  streamOffsetMs Int
  durationMs     Int
  mimeType       String
  status         MeetingAudioBatchStatus @default(PENDING)
  error          String?
  processedAt    DateTime?
  meetingId      String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  meeting        Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([streamId, sourceType, sequenceStart, sequenceEnd])
  @@index([meetingId, createdAt])
}

model MeetingExtractionChunk {
  id               String                       @id @default(cuid())
  meetingId        String
  chunkIndex       Int
  newContentStartMs Int
  promptStartMs    Int
  promptEndMs      Int
  status           MeetingExtractionChunkStatus @default(PENDING)
  partialSummary   String?
  taskMutationsJson Json?
  retryCount       Int                          @default(0)
  lastError        String?
  processedAt      DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  meeting          Meeting                      @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, chunkIndex])
  @@index([meetingId, status, chunkIndex])
}

model MeetingArtifactDraft {
  id                    String                                @id @default(cuid())
  meetingId             String                                @unique
  rollingTasksJson      Json
  lastCompletedChunkIndex Int                                 @default(-1)
  finalizationStatus    MeetingArtifactDraftFinalizationStatus @default(PENDING)
  lastError             String?
  createdAt             DateTime                              @default(now())
  updatedAt             DateTime                              @updatedAt
  meeting               Meeting                               @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model SpeakerProfile {
  id          String              @id @default(cuid())
  aiLabel     String
  realName    String?
  meetingId   String
  voiceProfileId String?
  recurringSpeakerProfileId String?
  recurringMatchConfidence Float?
  recurringMatchSeenCount Int?
  actionItems ActionItem[]
  meeting     Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  segments    TranscriptSegment[]
  voiceProfile VoiceProfile?      @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  evidenceSamples MeetingSpeakerSample[]
  promotedSamples VoiceProfileSample[] @relation("VoiceProfileSampleSourceSpeaker")
  recurringSpeakerProfile RecurringSpeakerProfile? @relation(fields: [recurringSpeakerProfileId], references: [id], onDelete: SetNull)
  recurringSamples RecurringSpeakerSample[] @relation("RecurringSpeakerSampleSourceSpeaker")

  @@unique([meetingId, aiLabel])
  @@index([meetingId, voiceProfileId])
  @@index([meetingId, recurringSpeakerProfileId])
}

model TranscriptSegment {
  id              String                  @id @default(cuid())
  startTime       Float
  endTime         Float
  content         String
  sourceType      AudioSourceType?
  mergeStrategy   TranscriptMergeStrategy?
  mergeSourceType AudioSourceType?
  isSuppressed    Boolean                 @default(false)
  suppressedAt    DateTime?
  speakerId       String
  meetingId       String
  meeting         Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker         SpeakerProfile          @relation(fields: [speakerId], references: [id])
}

model VoiceProfile {
  id               String                  @id @default(cuid())
  displayName      String
  position         String?
  department       String?
  isActive         Boolean                 @default(true)
  workerCacheStatus WorkerCacheSyncStatus  @default(PENDING)
  workerCacheError String?
  lastSyncedAt     DateTime?
  userId           String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  samples          VoiceProfileSample[]
  mappedSpeakers   SpeakerProfile[]
  promotedRecurringSpeakerProfiles RecurringSpeakerProfile[] @relation("PromotedVoiceProfile")

  @@unique([userId, displayName])
  @@index([userId, isActive, workerCacheStatus])
}

model RecurringSpeakerProfile {
  id                    String                        @id @default(cuid())
  userId                String
  status                RecurringSpeakerProfileStatus @default(CANDIDATE)
  lastSeenAt            DateTime
  meetingCount          Int                           @default(1)
  sampleCount           Int                           @default(0)
  promotedVoiceProfileId String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  promotedVoiceProfile  VoiceProfile?                 @relation("PromotedVoiceProfile", fields: [promotedVoiceProfileId], references: [id], onDelete: SetNull)
  user                  User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  samples               RecurringSpeakerSample[]
  linkedSpeakers        SpeakerProfile[]

  @@index([userId, status, lastSeenAt])
  @@index([promotedVoiceProfileId])
}

model RecurringSpeakerSample {
  id                       String                  @id @default(cuid())
  recurringSpeakerProfileId String
  embedding                Json
  durationSeconds          Float
  rmsDb                    Float?
  speechRatio              Float?
  qualityScore             Float?
  sampleRate               Int?
  sourceMeetingId          String?
  sourceSpeakerProfileId   String?
  createdAt                DateTime                @default(now())
  recurringSpeakerProfile  RecurringSpeakerProfile  @relation(fields: [recurringSpeakerProfileId], references: [id], onDelete: Cascade)
  sourceMeeting            Meeting?                 @relation(fields: [sourceMeetingId], references: [id], onDelete: SetNull)
  sourceSpeakerProfile     SpeakerProfile?          @relation("RecurringSpeakerSampleSourceSpeaker", fields: [sourceSpeakerProfileId], references: [id], onDelete: SetNull)

  @@index([recurringSpeakerProfileId, createdAt])
  @@index([sourceMeetingId])
  @@index([sourceSpeakerProfileId])
}

model VoiceProfileSample {
  id                    String                   @id @default(cuid())
  voiceProfileId        String
  source                VoiceProfileSampleSource
  embedding             Json
  durationSeconds       Float
  rmsDb                 Float?
  speechRatio           Float?
  qualityScore          Float?
  sampleRate            Int?
  sourceMeetingId       String?
  sourceSpeakerProfileId String?
  createdAt             DateTime                 @default(now())
  sourceMeeting         Meeting?                 @relation(fields: [sourceMeetingId], references: [id], onDelete: SetNull)
  sourceSpeakerProfile  SpeakerProfile?          @relation("VoiceProfileSampleSourceSpeaker", fields: [sourceSpeakerProfileId], references: [id], onDelete: SetNull)
  voiceProfile          VoiceProfile             @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)

  @@index([voiceProfileId, createdAt])
  @@index([sourceMeetingId])
  @@index([sourceSpeakerProfileId])
}

model MeetingSpeakerSample {
  id              String           @id @default(cuid())
  speakerProfileId String
  embedding       Json
  startTime       Float
  endTime         Float
  durationSeconds Float
  sourceType      AudioSourceType?
  rmsDb           Float?
  speechRatio     Float?
  qualityScore    Float?
  sampleRate      Int?
  createdAt       DateTime         @default(now())
  speakerProfile  SpeakerProfile   @relation(fields: [speakerProfileId], references: [id], onDelete: Cascade)

  @@index([speakerProfileId, createdAt])
}

enum CaptureContext {
  GOOGLE_MEET_ROOM
  GENERIC_TAB
}

enum AudioSourceType {
  TAB_MIX
  SELF_MIC
}

enum TranscriptMergeStrategy {
  PREFERRED_SELF_MIC_DUPLICATE
  AMBIGUOUS_OVERLAP
}

enum WorkerCacheSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum RecurringSpeakerProfileStatus {
  CANDIDATE
  STABLE
  PROMOTED
}

enum MeetingSpeakerPostProcessStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VoiceProfileSampleSource {
  UPLOAD
  MEETING_PROMOTION
}

model ActionItem {
  id           String           @id @default(cuid())
  taskContent  String
  deadline     DateTime?
  status       ActionItemStatus @default(TODO)
  isSynced     Boolean          @default(false)
  notionPageId String?
  assigneeId   String?
  meetingId    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt
  assignee     SpeakerProfile?  @relation(fields: [assigneeId], references: [id])
  meeting      Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model NotionConnection {
  id             String   @id @default(cuid())
  botId          String   @unique
  accessToken    String
  refreshToken   String?
  workspaceId    String
  workspaceName  String?
  workspaceIcon  String?
  ownerUserId    String?
  ownerUserName  String?
  ownerUserEmail String?
  userId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum MeetingStatus {
  RECORDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MeetingIngestionSource {
  LIVE_CAPTURE
  FILE_UPLOAD
}

enum MeetingArtifactReviewStatus {
  PENDING
  READY
  APPROVED
  FAILED
}

enum ActionItemStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ProjectContextProposalStatus {
  PENDING
  APPLIED
  DISMISSED
}

enum MeetingAudioBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MeetingExtractionChunkStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MeetingArtifactDraftFinalizationStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum NotionProjectDestinationMode {
  PROJECT_PAGE
  EXISTING_PAGE
}

enum PlanTier {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}
