{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd .. && pnpm build:contracts && pnpm build:webapp",
  "outputDirectory": "dist",
  "installCommand": "cd .. && pnpm i && cd kapter-webapp",
  "framework": "vite",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
