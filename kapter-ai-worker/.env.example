KAPTER_AI_CHUNK_DURATION_SECONDS=2.0
KAPTER_AI_STREAM_DELAY_RATIO=0.0
KAPTER_AI_EXPECTED_SAMPLE_RATE=
KAPTER_AI_VAD_ENERGY_THRESHOLD=0.01
KAPTER_AI_DEFAULT_SPEAKER_PREFIX=SPEAKER
KAPTER_AI_LOG_LEVEL=DEBUG
KAPTER_AI_FFMPEG_BIN=
KAPTER_AI_SHARED_SECRET=
KAPTER_AI_VOICE_PROFILE_CACHE_PATH=voice_profile_cache.json

# --- Real model settings ---
KAPTER_AI_USE_REAL_MODELS=true
KAPTER_AI_DEVICE=cuda
KAPTER_AI_HF_TOKEN=hf_your_token_here
KAPTER_AI_LANGUAGE=

# Faster Whisper (uses HuggingFace cache by default, no local download)
KAPTER_AI_FASTER_WHISPER_MODEL_NAME=large-v3-turbo
KAPTER_AI_FASTER_WHISPER_MODEL_DIR=
KAPTER_AI_FASTER_WHISPER_COMPUTE_TYPE=int8_float16
KAPTER_AI_FASTER_WHISPER_BEAM_SIZE=5

# Pyannote (uses HuggingFace cache by default, no local download)
KAPTER_AI_PYANNOTE_MODEL_NAME=pyannote/speaker-diarization-3.1
KAPTER_AI_PYANNOTE_MODEL_DIR=
KAPTER_AI_DIARIZATION_THRESHOLD=0.4
KAPTER_AI_SPEAKER_MATCH_THRESHOLD=0.55
KAPTER_AI_SPEAKER_GLUE_THRESHOLD=0.45
KAPTER_AI_SPEAKER_MERGE_THRESHOLD=0.70
KAPTER_AI_MIN_EMBEDDING_DURATION=1.25

# Silero VAD
KAPTER_AI_SILERO_VAD_THRESHOLD=0.4

# Anti-hallucination
KAPTER_AI_HALLUCINATION_LOGPROB_THRESHOLD=-1.0
KAPTER_AI_MAX_SEGMENT_REPEAT=2
KAPTER_AI_MIN_AUDIO_RMS=0.01

KAPTER_AI_REAL_MODEL_CHUNK_DURATION_SECONDS=30.0
KAPTER_AI_REAL_MODEL_OVERLAP_DURATION_SECONDS=5.0
