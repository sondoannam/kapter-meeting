{
  "name": "extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @kapter/contracts build",
    "dev": "vite build --watch --mode development",
    "prebuild": "pnpm --filter @kapter/contracts build",
    "build": "tsc -b && vite build --mode production",
    "package:zip": "pnpm build && node ./scripts/package-extension.mjs",
    "start": "node ws-test-server.js",
    "lint": "eslint .",
    "test:package": "node --test ./scripts/package-extension.test.mjs",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@kapter/contracts": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.2",
    "webextension-polyfill": "^0.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.17",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-web-extension": "^4.5.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
