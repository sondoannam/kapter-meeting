{
  "manifest_version": 3,
  "name": "Kapter — Meeting Audio Capture",
  "version": "0.1.0",
  "description": "Capture Google Meet audio and stream to Kapter AI backend.",

  "action": {
    "default_popup": "src/popup/index.html"
  },

  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/index.js"],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "tabCapture",
    "offscreen"
  ],

  "host_permissions": ["https://meet.google.com/*"],

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
